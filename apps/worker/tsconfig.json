{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@motion/database": ["../../packages/database/src"],
      "@motion/queue": ["../../packages/queue/src"],
      "@motion/storage": ["../../packages/storage/src"],
      "@motion/ai-providers": ["../../packages/ai-providers/src"]
    }
  },
  "include": ["src/**/*"]
}
