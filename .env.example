# Database
DATABASE_URL="postgresql://motion:motion123@localhost:5432/motion_transfer"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth (better-auth)
BETTER_AUTH_SECRET="your-secret-key-change-this-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# Storage
STORAGE_TYPE="local"
STORAGE_LOCAL_PATH="./uploads"
# For S3/R2 (optional):
# STORAGE_TYPE="s3"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="us-east-1"
# AWS_BUCKET_NAME=""
# AWS_ENDPOINT_URL="" # for R2/custom S3

# AI Provider
AI_PROVIDER="mock"
# For Replicate:
# AI_PROVIDER="replicate"
# REPLICATE_API_TOKEN=""
# REPLICATE_MOTION_MODEL="stability-ai/stable-video-diffusion"
# For ComfyUI:
# AI_PROVIDER="comfyui"
# COMFYUI_URL="http://localhost:8188"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── TikTok Shop Auto UGC ─────────────────────────────────
# RapidAPI key for TikTok Scraper (leave empty to use mock data)
# Get at: https://rapidapi.com/search/tiktok-scraper7
RAPIDAPI_KEY=""

# Cron secret for automated daily scheduler
# Set a random string and use it in Vercel Cron config
CRON_SECRET="your-cron-secret-here"

# Already configured (used by UGC module):
# OPENAI_API_KEY          — GPT-4o Mini (copy/brief/prompts) + TTS (narration)
# GOOGLE_SERVICE_ACCOUNT_JSON — Veo 3 via Vertex AI
# GOOGLE_CLOUD_PROJECT    — GCP project ID (default: gen-lang-client-0466084510)
# GOOGLE_AI_API_KEY       — For GCS video download
# BLOB_READ_WRITE_TOKEN   — Vercel Blob storage
