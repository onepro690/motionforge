{
  "installCommand": "npm install",
  "buildCommand": "(cd apps/web && ../../node_modules/.bin/prisma generate --schema=../../packages/database/prisma/schema.prisma && ../../node_modules/.bin/next build)",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/ugc/scheduler",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/record-lives",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/discover-lives",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/poll-ugc-videos",
      "schedule": "*/2 * * * *"
    }
  ]
}
